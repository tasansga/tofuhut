# Minimal ansible workload example
WORKLOAD_TYPE=ansible
MODE=plan

# Optional approval and notifications:
# MODE=apply
# WORKLOAD_TOKEN=change-me
# NTFY_URL=https://ntfy.example.internal
# NTFY_TOPIC=tofuhut-approvals
# NTFY_TOKEN=...
# APPROVE_URL=https://tofuhut.example.internal

# Optional scheduler controls (server --enable-scheduler):
# RECONCILE_ENABLED=true
# RECONCILE_INTERVAL=15m
