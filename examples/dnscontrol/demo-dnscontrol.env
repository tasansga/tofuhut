# Minimal dnscontrol workload example
WORKLOAD_TYPE=dnscontrol
MODE=plan

# Optional approval and notifications:
# MODE=apply
# WORKLOAD_TOKEN=change-me
# NTFY_URL=https://ntfy.example.internal
# NTFY_TOPIC=tofuhut-approvals
# NTFY_TOKEN=...
# APPROVE_URL=https://tofuhut.example.internal

# Provider credentials should be defined here.
# Example placeholders:
# CLOUDFLARE_API_TOKEN=...
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
