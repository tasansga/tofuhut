# Environment for workload: <name>
#
# WORKLOAD_TYPE: required (tofu, ansible, or dnscontrol)
# WORKLOAD_TYPE=tofu
#
# MODE: plan, apply, or auto-apply
# MODE=plan
#
# For ansible workloads, place a playbook at:
# ${TOFUHUT_WORKLOAD_RUNTIME_DIR}/<name>/playbook.yml
#
# For dnscontrol workloads, place dnscontrol config at:
# ${TOFUHUT_WORKLOAD_RUNTIME_DIR}/<name>/dnsconfig.js
#
# Optional OpenTofu init flags
# UPGRADE=false
# RECONFIGURE=false
#
# Optional scheduler gate for ansible/dnscontrol:
# when true, reconcile only when playbook.yml/dnsconfig.js changed
# RECONCILE_CHANGED_ONLY=false
#
# Optional hooks (absolute script paths)
# PRE_RECONCILE_HOOK=/usr/local/bin/tofuhut-pre.sh
# POST_RECONCILE_HOOK=/usr/local/bin/tofuhut-post.sh
# PRE_RECONCILE_TIMEOUT=30s
# POST_RECONCILE_TIMEOUT=30s
#
# Optional Gatus integration
# GATUS_CLI_URL=https://gatus.example.internal/api/v1
# GATUS_CLI_TOKEN=...
#
# Optional ntfy notification when approval is required
# NTFY_URL=https://ntfy.example.internal
# NTFY_TOPIC=tofuhut-approvals
# NTFY_TOKEN=...
#
# Optional approval webhook (used for ntfy action button)
# APPROVE_URL=https://tofuhut-approver.example.internal
# WORKLOAD_TOKEN=...
#
# Example TF variables / provider settings
# TF_VAR_grantory_server=...
# PG_CONN_STR=postgres://user:pass@host/db?sslmode=require
